{
  "name": "vchat",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prepare": "husky",
    "format": "prettier --write \"src/app/**/{page,layout}.tsx\" \"src/app/globals.css\" \"src/components/**/*.{ts,tsx}\" \"src/hooks/**/*.{ts,tsx}\" \"src/stores/**/*.{ts,tsx}\" \"src/types/**/*.{ts,tsx}\" \"package.json\" \".prettierrc.json\" \".github/**/*.{yml,yaml}\"",
    "format:check": "prettier --check \"src/app/**/{page,layout}.tsx\" \"src/app/globals.css\" \"src/components/**/*.{ts,tsx}\" \"src/hooks/**/*.{ts,tsx}\" \"src/stores/**/*.{ts,tsx}\" \"src/types/**/*.{ts,tsx}\" \"package.json\" \".prettierrc.json\" \".github/**/*.{yml,yaml}\"",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "check:markdown-sanitize": "tsx scripts/check-markdown-sanitize.ts",
    "check:chat-context": "tsx scripts/check-chat-context.ts",
    "check:sse-stream": "tsx scripts/check-sse-stream.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "node scripts/db-seed.mjs",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-select": "^2.2.6",
    "ai": "^6.0.168",
    "dompurify": "^3.4.7",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "markdown-it": "^14.1.1",
    "next": "16.2.4",
    "openai": "^6.34.0",
    "pgvector": "^0.2.1",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-virtuoso": "^4.18.7",
    "tencentcloud-sdk-nodejs": "^4.1.229",
    "use-immer": "^0.11.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2",
    "zustand": "^5.0.12"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@iconify/react": "^6.0.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
